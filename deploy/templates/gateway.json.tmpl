{
  "api_keys": [
    {
      "key": "${GATEWAY_API_KEY}",
      "user_address": "${SENDER_ADDRESS}",
      "query_status": "ACTIVE"
    }
  ],
  "attestations": {
    "chain_id": "${CHAIN_ID}",
    "dispute_manager": "${DISPUTE_MANAGER}"
  },
  "exchange_rate_provider": ${GRT_USD},
  "graph_env_id": "lodestar-mainnet",
  "kafka": {
    "bootstrap.servers": "redpanda:9092"
  },
  "log_json": false,
  "min_graph_node_version": "0.0.0",
  "min_indexer_version": "0.0.0",
  "network_subgraph_max_lag_seconds": 300,
  "trusted_indexers": [
    {
      "url": "${NETWORK_SUBGRAPH_URL}",
      "auth": "${NETWORK_SUBGRAPH_AUTH}"
    }
  ],
  "payment_required": false,
  "port_api": 7700,
  "port_metrics": 7301,
  "query_fees_target": ${QUERY_FEES_TARGET},
  "receipts": {
    "chain_id": "${CHAIN_ID}",
    "payer": "${SENDER_ADDRESS}",
    "signer": "${SIGNER_KEY}",
    "verifier": "${GRAPH_TALLY_COLLECTOR}"
  },
  "subgraph_service": "${SUBGRAPH_SERVICE}"
}
