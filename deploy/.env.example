# lodestar-gateway deploy config — copy to .env and fill the TODOs.
# render.sh injects SIGNER_KEY/SENDER_KEY from /root/gw-secrets/*.txt (never put keys here).

# --- Verified Arbitrum One contract addresses (chain 42161) — see ../PLAN.md ---
CHAIN_ID=42161
GRT=0x9623063377AD1B27544C965cCd7342f7EA7e88C7
GRAPH_TALLY_COLLECTOR=0x8f69F5C07477Ac46FBc491B1E6D91E2bb0111A9e
PAYMENTS_ESCROW=0xf6Fcc27aAf1fcD8B254498c9794451d82afC673E
SUBGRAPH_SERVICE=0xb2Bb92d0DE618878E438b55D5846cfecD9301105
DISPUTE_MANAGER=0x2FE023a575449AcB698648eD21276293Fa176f96

# --- Sender (payer) address; private key lives in /root/gw-secrets/sender.txt ---
SENDER_ADDRESS=0xE941D672C00A730AE675945007A6C0C76057C51b

# --- Arbitrum One RPC ---
ARB_RPC=https://arb1.arbitrum.io/rpc

# --- Network subgraph (keyed public endpoint) — TODO: fill both ---
# Full GraphQL query URL for the Graph Network subgraph on Arbitrum One.
NETWORK_SUBGRAPH_URL=
# Bearer/auth token if the endpoint needs one (leave empty if the key is in the URL path).
NETWORK_SUBGRAPH_AUTH=

# --- Consumer side ---
# Static API key clients send as `Authorization: Bearer <key>` (we're the only consumer).
GATEWAY_API_KEY=
# Fixed GRT price in USD, used for query-fee budgeting (approximate; refine later).
GRT_USD=0.09
# Target indexer fee paid per query, in USD.
QUERY_FEES_TARGET=20e-6
# Escrow GRT allowance ceiling the escrow-manager may approve/deposit.
GRT_ALLOWANCE=1000

# --- Ports (published on the VPS) ---
GATEWAY_PORT=7700
AGGREGATOR_PORT=7610
